# anfinances backend — пример переменных окружения.
#
# Скопируй в .env и заполни.
#   cp .env.example .env
#
# Файл .env закоммичен в .gitignore — твои значения не уйдут в репо.

# ═══════════════════════════════════════════════════════════════════════
# Окружение
# ═══════════════════════════════════════════════════════════════════════

# development | production | test
ENVIRONMENT=development

# Включает дебаг-режим FastAPI и подробные ошибки. В проде — false.
DEBUG=true

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ═══════════════════════════════════════════════════════════════════════
# API
# ═══════════════════════════════════════════════════════════════════════

# Список разрешённых origins для CORS (JSON-массив).
# Для dev frontend на Vite — http://localhost:5173.
CORS_ORIGINS=["http://localhost:5173"]


# ═══════════════════════════════════════════════════════════════════════
# База данных
# ═══════════════════════════════════════════════════════════════════════

# Внутри docker-compose хост = "postgres" (имя сервиса).
# При локальном запуске без compose — "localhost".
# В docker-compose.yml POSTGRES_HOST переопределяется автоматически.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=anfinances
POSTGRES_PASSWORD=anfinances
POSTGRES_DB=anfinances

# Параметры пула SQLAlchemy. Дефолты ок для self-host на одного юзера.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Логировать SQL в stdout. Полезно при отладке, в проде — false.
DB_ECHO=false


# ═══════════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════════

# Секретный ключ для подписи JWT. Минимум 32 байта.
# Сгенерируй командой:
#   openssl rand -hex 32
# НИ В КОЕМ СЛУЧАЕ не используй значение ниже в production.
SECRET_KEY=change-me-use-openssl-rand-hex-32-to-generate

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Refresh-токен хранится в HttpOnly cookie.
# В dev по http выставь false (браузер не шлёт Secure-cookie по http).
# В проде на https — обязательно true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ═══════════════════════════════════════════════════════════════════════
# Auth-режим
# ═══════════════════════════════════════════════════════════════════════
#
# Реализация в шаге 3. Сейчас переменные читаются, но не используются.
#
# single_user            — для self-host одного человека. Регистрация выключена,
#                          учётка задаётся ниже через SINGLE_USER_*.
# multi_user_no_verify   — открытая регистрация без email-верификации.
#                          Для своего хостинга без SMTP.
# multi_user             — открытая регистрация с email-верификацией.
#                          Для публичного SaaS. Требует SMTP_*.

AUTH_MODE=single_user

# Только для AUTH_MODE=single_user.
# При старте приложение проверит наличие юзера с таким email и создаст его,
# если нет. Пароль хешируется и сохраняется в БД (plain в .env нужен только
# для первоначальной настройки).
SINGLE_USER_EMAIL=
SINGLE_USER_PASSWORD=


# ═══════════════════════════════════════════════════════════════════════
# SMTP (нужен только для AUTH_MODE=multi_user)
# ═══════════════════════════════════════════════════════════════════════

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=


# ═══════════════════════════════════════════════════════════════════════
# Currencies
# ═══════════════════════════════════════════════════════════════════════

# По умолчанию — бесплатный open.er-api.com, без ключа.
# При желании можно подключить платный провайдер (ключ ниже).
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest
EXCHANGE_RATE_API_KEY=


# ═══════════════════════════════════════════════════════════════════════
# Docker (используются только в docker-compose.yml)
# ═══════════════════════════════════════════════════════════════════════

# На какой порт хоста маппить backend и postgres.
BACKEND_PORT=8000
# Для prod-compose: на какой порт hostb-машины слушает nginx.
HTTP_PORT=80

PASSWORD_MIN_LENGTH=15
HIBP_ENABLED=true
HIBP_FAIL_OPEN=true
